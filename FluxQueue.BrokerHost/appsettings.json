{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "ServiceName": "FluxQueue.BrokerHost",
    "Otlp": {
      "Enabled": false,
      "Endpoint": "http://localhost:4317",
      "Headers": ""
    },
    "Console": {
      "Enabled": false,
      "MetricsEnabled": false,
      "TracingEnabled": false,
      "MetricsExportIntervalMilliseconds": 5000
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:8081",
        "Protocols": "Http2"
      }
    }
  },
  "FluxQueue": {
    "DbPath": "/data/rocksdb",
    "Reconciler": {
      "Enabled": true,
      "WipeAndRebuildIndexes": false,
      "MaxMessages": 5000000,
      "SweepBatchSize": 20000
    },
    "Sweeper": {
      "Enabled": true,
      "MaxExpiredMessagesPerQueuePerTick": 2000,
      "MaxQueuesPerTick": 50,
      "IdleDelayMs": 250,
      "BusyDelayMs": 10,
      "ErrorBackoffSeconds": 5
    },
    "Defaults": {
      "MaxMessageSizeBytes": 262144,
      "MaxBatchReceiveMessages": 10,
      "MaxVisibilityTimeoutSeconds": 43200,
      "MaxWaitSeconds": 20,
      "DefaultVisibilityTimeoutSeconds": 30,
      "DefaultWaitSeconds": 0,
      "MaxReceiveCount": 5
    },
    "Amqp": {
      "Enabled": true,
      "BindAddress": "0.0.0.0",
      "Port": 5673,
      "MaxBatch": 50,
      "DefaultVisibilityTimeoutSeconds": 30,
      "DefaultWaitSeconds": 5,
      "IngressInitialCredit": 200,
      "EgressInitialCredit": 50,
      "MaxConnections": 1000,
      "MaxSessionsPerConnection": 50,
      "MaxLinksPerSession": 100
    }
  }
}
