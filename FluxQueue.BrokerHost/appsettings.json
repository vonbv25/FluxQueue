{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:8081",
        "Protocols": "Http2"
      }
    }
  },
  "FluxQueue": {
    "DbPath": "/data/rocksdb",
    "Reconciler": {
      "Enabled": true,
      "IntervalSeconds": 60,
      "WipeAndRebuildIndexes": false,
      "MaxMessages": 5000000,
      "SweepBatchSize": 20000
    },
    "Sweeper": {
      "Enabled": true,
      "IntervalMilliseconds": 500,
      "BatchSize": 1000
    },
    "Amqp": {
      "Port": 5672,
      "DefaultVisibilityTimeoutSeconds": 30,
      "DefaultWaitSeconds": 1,
      "MaxBatch": 50
    },
    "Defaults": {
      "MaxMessageSizeBytes": 262144,
      "MaxInflightPerQueue": 1000,
      "DefaultVisibilityTimeoutSeconds": 30,
      "MaxVisibilityTimeoutSeconds": 300,
      "DefaultWaitSeconds": 1,
      "MaxWaitSeconds": 30,
      "MaxReceiveCount": 5,
      "MaxBatchReceiveMessages": 50
    }
  }
}