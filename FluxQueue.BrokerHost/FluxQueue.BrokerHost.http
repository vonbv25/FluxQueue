@baseUrl = http://localhost:8080
@apiBase = {{baseUrl}}/api/v1/queues
@queue = demo
@receiptHandle = yHEvcCs2i1cM18dQpxkxKXlxWPPwWK6S

###
# =========================================================
# FluxQueue HTTP Tester
# =========================================================

###
# Root
GET {{baseUrl}}/
Accept: text/plain

###
# =========================================================
# 1. Send Messages
# =========================================================

###
# Send: immediate message
# "hello world" -> aGVsbG8gd29ybGQ=
POST {{apiBase}}/{{queue}}/messages
Content-Type: application/json
Accept: application/json

{
  "payloadBase64": "aGVsbG8gd29ybGQ=",
  "delaySeconds": 0,
  "maxReceiveCount": 5
}

###
# Send: delayed message
# "delayed message" -> ZGVsYXllZCBtZXNzYWdl
POST {{apiBase}}/{{queue}}/messages
Content-Type: application/json
Accept: application/json

{
  "payloadBase64": "ZGVsYXllZCBtZXNzYWdl",
  "delaySeconds": 5,
  "maxReceiveCount": 5
}

###
# Send: empty payload
POST {{apiBase}}/{{queue}}/messages
Content-Type: application/json
Accept: application/json

{
  "payloadBase64": null,
  "delaySeconds": 0,
  "maxReceiveCount": 5
}

###
# Send: invalid base64
POST {{apiBase}}/{{queue}}/messages
Content-Type: application/json
Accept: application/json

{
  "payloadBase64": "%%%not-base64%%%",
  "delaySeconds": 0,
  "maxReceiveCount": 5
}

###
# =========================================================
# 2. Receive Messages
# =========================================================

###
# Receive: long poll
POST {{apiBase}}/{{queue}}/messages:receive
Content-Type: application/json
Accept: application/json

{
  "maxMessages": 5,
  "visibilityTimeoutSeconds": 30,
  "waitSeconds": 10
}

###
# Receive: single message, short visibility timeout
POST {{apiBase}}/{{queue}}/messages:receive
Content-Type: application/json
Accept: application/json

{
  "maxMessages": 1,
  "visibilityTimeoutSeconds": 5,
  "waitSeconds": 0
}

###
# Receive: invalid maxMessages
POST {{apiBase}}/{{queue}}/messages:receive
Content-Type: application/json
Accept: application/json

{
  "maxMessages": 0,
  "visibilityTimeoutSeconds": 5,
  "waitSeconds": 0
}

###
# =========================================================
# 3. Ack Flow
# =========================================================

###
# Ack: primary route
# Replace {{receiptHandle}} with a receiptHandle from receive response
POST {{apiBase}}/{{queue}}/receipts/{{receiptHandle}}:ack
Accept: application/json

###
# Ack: invalid receipt handle
POST {{apiBase}}/{{queue}}/receipts/invalid-handle-123:ack
Accept: application/json

###
# Ack: legacy route (still supported)
DELETE {{apiBase}}/{{queue}}/receipts/{{receiptHandle}}

###
# =========================================================
# 4. Reject Flow
# =========================================================

###
# Reject: primary route
# Reject moves the message to the DLQ
POST {{apiBase}}/{{queue}}/receipts/{{receiptHandle}}:reject
Accept: application/json

###
# Reject: invalid receipt handle
POST {{apiBase}}/{{queue}}/receipts/invalid-handle-123:reject
Accept: application/json

###
# =========================================================
# 5. Suggested Happy Path
# =========================================================

###
# Step 1: Send
POST {{apiBase}}/{{queue}}/messages
Content-Type: application/json
Accept: application/json

{
  "payloadBase64": "aGVsbG8gZmx1eHF1ZXVl",
  "delaySeconds": 0,
  "maxReceiveCount": 5
}

###
# Step 2: Receive
# Copy receiptHandle from the response into @receiptHandle above
POST {{apiBase}}/{{queue}}/messages:receive
Content-Type: application/json
Accept: application/json

{
  "maxMessages": 1,
  "visibilityTimeoutSeconds": 30,
  "waitSeconds": 0
}

###
# Step 3: Ack
POST {{apiBase}}/{{queue}}/receipts/{{receiptHandle}}:ack
Accept: application/json

###
# =========================================================
# 6. Suggested Reject / DLQ Flow
# =========================================================

###
# Step 1: Send message for rejection test
POST {{apiBase}}/{{queue}}/messages
Content-Type: application/json
Accept: application/json

{
  "payloadBase64": "cmVqZWN0LW1l",
  "delaySeconds": 0,
  "maxReceiveCount": 5
}

###
# Step 2: Receive
# Copy receiptHandle from the response into @receiptHandle above
POST {{apiBase}}/{{queue}}/messages:receive
Content-Type: application/json
Accept: application/json

{
  "maxMessages": 1,
  "visibilityTimeoutSeconds": 30,
  "waitSeconds": 0
}

###
# Step 3: Reject
POST {{apiBase}}/{{queue}}/receipts/{{receiptHandle}}:reject
Accept: application/json